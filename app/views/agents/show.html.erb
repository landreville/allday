<div class="agent-details-page">
  <div class="page-header">
    <div class="breadcrumb">
      <%= link_to "← Back to Agents", agents_path, class: "back-link" %>
    </div>
    <div class="agent-title">
      <h1><%= @agent.name %></h1>
      <span class="status-badge <%= @agent.status %>">
        <%= @agent.status.to_s.humanize %>
      </span>
    </div>
  </div>

  <div class="agent-info-panel">
    <div class="info-grid">
      <div class="info-item">
        <span class="label">Client:</span>
        <span class="value"><%= @agent.client || 'Unknown' %></span>
      </div>

      <div class="info-item">
        <span class="label">Model:</span>
        <span class="value"><%= @agent.llm_model || 'Not specified' %></span>
      </div>

      <div class="info-item">
        <span class="label">Origin:</span>
        <span class="value"><%= @agent.origin.humanize %></span>
      </div>

      <div class="info-item">
        <span class="label">Transcripts:</span>
        <span class="value"><%= pluralize(@agent.transcripts.count, 'transcript') %></span>
      </div>

      <div class="info-item">
        <span class="label">Total Messages:</span>
        <span class="value"><%= @messages.count %></span>
      </div>

      <div class="info-item">
        <span class="label">Memories:</span>
        <span class="value"><%= @memory_chunks.count %></span>
      </div>

      <% if @agent.last_activity %>
        <div class="info-item">
          <span class="label">Last Activity:</span>
          <span class="value" title="<%= @agent.last_activity %>">
            <%= time_ago_in_words(@agent.last_activity) %> ago
          </span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="content-tabs-section">
    <div class="tabs-nav">
      <button class="tab-button active" data-tab="conversation">
        <span class="tab-label">Conversation History</span>
        <span class="tab-count"><%= @messages.count %></span>
      </button>
      <button class="tab-button" data-tab="memories">
        <span class="tab-label">Memories</span>
        <span class="tab-count"><%= @memory_chunks.count %></span>
      </button>
    </div>

    <div class="tab-content active" id="conversation-tab">
      <div class="tab-header">
        <p class="tab-description">
          Messages from all transcripts shown in chronological order
        </p>
      </div>

      <div class="content-container" id="messages-container">
        <% if @messages.empty? %>
          <div class="empty-state">
            <div class="empty-icon">💬</div>
            <h3>No messages yet</h3>
            <p>Messages will appear here as this agent participates in conversations.</p>
          </div>
        <% else %>
          <% @messages.group_by(&:transcript).each do |transcript, messages| %>
            <div class="transcript-group">
              <div class="transcript-header-small">
                <h4>Transcript from <%= transcript.source %></h4>
                <span class="transcript-status <%= transcript.status %>">
                  <%= transcript.status.humanize %>
                </span>
              </div>

              <div class="messages-list">
                <% messages.each do |message| %>
                  <div class="message <%= message.role %>" data-sequence="<%= message.sequence %>">
                    <div class="message-header">
                      <span class="role-badge <%= message.role %>">
                        <%= message.role.humanize %>
                      </span>
                      <span class="sequence">#<%= message.sequence %></span>
                      <% if message.timestamp %>
                        <span class="timestamp" title="<%= message.timestamp %>">
                          <%= time_ago_in_words(message.timestamp) %> ago
                        </span>
                      <% end %>
                    </div>

                    <div class="message-content">
                      <% if message.content.present? %>
                        <div class="content">
                          <%= simple_format(h(message.content), {}, wrapper_tag: "div") %>
                        </div>
                      <% end %>

                      <% if message.thinking.present? %>
                        <details class="thinking-section">
                          <summary>Agent Thinking</summary>
                          <div class="thinking-content">
                            <%= simple_format(h(message.thinking), {}, wrapper_tag: "div") %>
                          </div>
                        </details>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="tab-content" id="memories-tab">
      <div class="tab-header">
        <p class="tab-description">
          Extracted memories and knowledge from conversations
        </p>
      </div>

      <div class="content-container">
        <% if @memory_chunks.empty? %>
          <div class="empty-state">
            <div class="empty-icon">🧠</div>
            <h3>No memories yet</h3>
            <p>The agent will create memories as it learns from conversations and experiences.</p>
          </div>
        <% else %>
          <div class="memories-grid">
            <% @memory_chunks.each do |memory| %>
              <div class="memory-card">
                <div class="memory-header">
                  <h4 class="memory-topic"><%= memory.topic %></h4>
                  <span class="memory-date" title="<%= memory.created_at %>">
                    <%= time_ago_in_words(memory.created_at) %> ago
                  </span>
                </div>

                <div class="memory-summary">
                  <%= simple_format(h(memory.summary), {}, wrapper_tag: "div") %>
                </div>

                <% if memory.skills_demonstrated.present? && memory.skills_demonstrated.any? %>
                  <div class="memory-skills">
                    <span class="skills-label">Skills:</span>
                    <div class="skills-list">
                      <% memory.skills_demonstrated.each do |skill| %>
                        <span class="skill-tag"><%= skill %></span>
                      <% end %>
                    </div>
                  </div>
                <% end %>

                <div class="memory-meta">
                  <span class="memory-source">
                    From: <%= memory.transcript.source %>
                  </span>
                  <% if memory.message_range_start && memory.message_range_end %>
                    <span class="memory-range">
                      Messages #<%= memory.message_range_start %>-<%= memory.message_range_end %>
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Tab switching functionality
    const tabButtons = document.querySelectorAll('.tab-button');
    const tabContents = document.querySelectorAll('.tab-content');

    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        const targetTab = button.getAttribute('data-tab');

        // Remove active class from all buttons and content
        tabButtons.forEach(btn => btn.classList.remove('active'));
        tabContents.forEach(content => content.classList.remove('active'));

        // Add active class to clicked button and corresponding content
        button.classList.add('active');
        document.getElementById(targetTab + '-tab').classList.add('active');
      });
    });

    // Auto-scroll to the bottom of messages container when conversation tab is active
    function scrollToBottom() {
      const conversationTab = document.getElementById('conversation-tab');
      if (conversationTab.classList.contains('active')) {
        const container = document.getElementById('messages-container');
        if (container) {
          container.scrollTop = container.scrollHeight;
        }
      }
    }

    // Scroll to bottom on page load
    scrollToBottom();

    // Scroll to bottom when switching to conversation tab
    const conversationButton = document.querySelector('[data-tab="conversation"]');
    if (conversationButton) {
      conversationButton.addEventListener('click', () => {
        setTimeout(scrollToBottom, 100);
      });
    }
  });
</script>


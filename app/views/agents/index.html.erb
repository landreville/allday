<div class="agents-header">
  <h2>Agents</h2>
  <p class="subtitle">Manage your AI agents and monitor their activity</p>
</div>

<div class="agents-grid">
  <% if @agents.empty? %>
    <div class="empty-state">
      <div class="empty-icon">🤖</div>
      <h3>No agents found</h3>
      <p>Your agents will appear here when they are created by connecting with Claude Code or through the API.</p>
    </div>
  <% else %>
    <% @agents.each do |agent| %>
      <div class="agent-card <%= agent.status %>">
        <div class="agent-header">
          <h3 class="agent-name"><%= agent.name %></h3>
          <span class="status-badge <%= agent.status %>">
            <%= agent.status.to_s.humanize %>
          </span>
        </div>

        <div class="agent-details">
          <div class="detail-item">
            <span class="label">Client:</span>
            <span class="value"><%= agent.client || 'Unknown' %></span>
          </div>

          <div class="detail-item">
            <span class="label">Model:</span>
            <span class="value"><%= agent.llm_model || 'Not specified' %></span>
          </div>

          <div class="detail-item">
            <span class="label">Origin:</span>
            <span class="value"><%= agent.origin.humanize %></span>
          </div>

          <div class="detail-item">
            <span class="label">Transcripts:</span>
            <span class="value"><%= agent.transcripts.count %></span>
          </div>

          <% if agent.last_activity %>
            <div class="detail-item">
              <span class="label">Last Activity:</span>
              <span class="value" title="<%= agent.last_activity %>">
                <%= time_ago_in_words(agent.last_activity) %> ago
              </span>
            </div>
          <% end %>
        </div>

        <% if agent.running? %>
          <div class="active-sessions">
            <span class="active-count">
              <%= pluralize(agent.transcripts.active.count, 'active session') %>
            </span>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>

<style>
  .agents-header {
    margin-bottom: 30px;
  }

  .agents-header h2 {
    margin: 0 0 8px 0;
    color: #1e293b;
    font-size: 28px;
    font-weight: 700;
  }

  .subtitle {
    margin: 0;
    color: #64748b;
    font-size: 16px;
  }

  .agents-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 24px;
  }

  .agent-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 24px;
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
    transition: box-shadow 0.2s;
  }

  .agent-card:hover {
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }

  .agent-card.running {
    border-left: 4px solid #10b981;
  }

  .agent-card.dormant {
    border-left: 4px solid #6b7280;
  }

  .agent-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
  }

  .agent-name {
    margin: 0;
    color: #1e293b;
    font-size: 20px;
    font-weight: 600;
    flex: 1;
    margin-right: 12px;
  }

  .status-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .status-badge.running {
    background-color: #d1fae5;
    color: #065f46;
  }

  .status-badge.dormant {
    background-color: #f3f4f6;
    color: #374151;
  }

  .agent-details {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .detail-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0;
  }

  .detail-item .label {
    color: #64748b;
    font-weight: 500;
    font-size: 14px;
  }

  .detail-item .value {
    color: #1e293b;
    font-weight: 500;
    font-size: 14px;
    text-align: right;
  }

  .active-sessions {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #e2e8f0;
  }

  .active-count {
    color: #10b981;
    font-weight: 600;
    font-size: 14px;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
  }

  .empty-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .empty-state h3 {
    margin: 0 0 8px 0;
    color: #1e293b;
    font-size: 20px;
    font-weight: 600;
  }

  .empty-state p {
    margin: 0;
    color: #64748b;
    max-width: 400px;
    margin: 0 auto;
  }
</style>
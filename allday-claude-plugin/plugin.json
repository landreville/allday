{
  "name": "allday-integration",
  "version": "1.0.0",
  "description": "Stream Claude Code sessions to All-Day app in real-time",
  "author": "All-Day Team",
  "hooks": {
    "session_start": "hooks/session_start.py",
    "session_end": "hooks/session_end.py",
    "user_prompt_submit": "hooks/user_prompt_submit.py",
    "pre_tool_use": "hooks/pre_tool_use.py",
    "post_tool_use": "hooks/post_tool_use.py",
    "stop": "hooks/assistant_response.py"
  },
  "commands": {
    "allday": "commands/allday_sync.py"
  },
  "agents": {
    "allday_reporter": "agents/allday_reporter.py"
  },
  "configuration": {
    "allday_api_url": {
      "type": "string",
      "default": "http://localhost:3000",
      "description": "All-Day API base URL"
    },
    "allday_api_key": {
      "type": "string",
      "required": true,
      "description": "All-Day API key for authentication"
    },
    "enable_streaming": {
      "type": "boolean",
      "default": true,
      "description": "Enable real-time streaming to All-Day"
    },
    "debug_mode": {
      "type": "boolean",
      "default": false,
      "description": "Enable debug logging"
    }
  },
  "dependencies": {
    "python": ">=3.8",
    "requests": ">=2.25.0"
  }
}